<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="NPS.Views.DetectWindow"
        Title="Detection Analysis"
        MinWidth="800" MinHeight="600" Width="1000" Height="700"
        WindowStartupLocation="CenterScreen">

    <Window.Styles>
        <Style Selector="TextBlock.h2">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style Selector="TextBlock.label">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
        </Style>
        <Style Selector="TextBlock.value">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button">
            <Setter Property="HorizontalContentAlignment" Value="Center"/>  
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*" Margin="24">
        
        <!-- HEADER -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto" Margin="0,0,0,24">
            <Button Grid.Column="0" Content="← Back" Click="OnBackClicked" Classes="secondary"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                <TextBlock Text="🔎" FontSize="20" VerticalAlignment="Center"/>
                <TextBlock Text="Detection &amp; Normalization Analysis" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="1" ColumnDefinitions="*, 360">
            
            <!-- LEFT: INPUT -->
            <StackPanel Grid.Column="0" Margin="0,0,24,0" Spacing="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="Source Text Analysis" Classes="label"/>
                    <TextBox Name="InputTextBox" 
                             AcceptsReturn="True" 
                             TextWrapping="Wrap" 
                             Height="280"
                             Watermark="Paste suspicious text here..." 
                             FontSize="14" 
                             FontFamily="Consolas, monospace"
                             BorderThickness="1" 
                             CornerRadius="6"/>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Button Content="Analyze Text" Click="OnAnalyzeClicked" Classes="accent" FontSize="14" FontWeight="Bold" Padding="24,10"/>
                    <Button Content="Load File" Click="OnLoadFileClicked" Classes="secondary"/>
                    <Button Content="Clear" Click="OnClearClicked" Classes="secondary"/>
                </StackPanel>
            </StackPanel>

            <!-- RIGHT: DASHBOARD -->
            <Border Grid.Column="1" Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" 
                    CornerRadius="12" Padding="24" BoxShadow="0 4 12 0 #10000000">
                <ScrollViewer>
                    <StackPanel Spacing="24">
                        
                        <!-- VERDICT HEADER -->
                        <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="4">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Name="VerdictIcon" Text="-" FontSize="24"/>
                                    <TextBlock Name="VerdictTitle" Text="WAITING FOR INPUT" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Name="VerdictSub" Text="Enter text and click Analyze to begin." TextWrapping="Wrap" FontSize="12" Opacity="0.8"/>
                            </StackPanel>
                        </Border>

                        <!-- METRICS GRID -->
                        <UniformGrid Columns="2" Rows="2">
                            <StackPanel Margin="0,0,12,12">
                                <TextBlock Text="Zero-Width" Classes="label"/>
                                <TextBlock Name="ZeroWidthCount" Text="0" Classes="value"/>
                            </StackPanel>
                            <StackPanel Margin="12,0,0,12">
                                <TextBlock Text="Homoglyphs" Classes="label"/>
                                <TextBlock Name="HomoglyphCount" Text="0" Classes="value"/>
                            </StackPanel>
                            <StackPanel Margin="0,12,12,0">
                                <TextBlock Text="Bidi Overrides" Classes="label"/>
                                <TextBlock Name="BidiCount" Text="0" Classes="value"/>
                            </StackPanel>
                            <StackPanel Margin="12,12,0,0">
                                <TextBlock Text="Risk Score" Classes="label"/>
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Name="ScoreValue" Text="0" Classes="value"/>
                                    <TextBlock Text="/ 100" VerticalAlignment="Bottom" Margin="0,0,0,6" Opacity="0.6"/>
                                </StackPanel>
                            </StackPanel>
                        </UniformGrid>

                        <!-- SCORE BAR -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="Threat Level Visualization" Classes="label"/>
                            <Border Height="8" CornerRadius="4" Background="{DynamicResource SystemControlBackgroundBaseMediumLowBrush}" HorizontalAlignment="Left" Width="200" ClipToBounds="True">
                                <Border Name="ScoreBar" Width="0" HorizontalAlignment="Left" Background="#5C6CF0"/>
                            </Border>
                        </StackPanel>

                        <Separator Height="1" Background="{DynamicResource SystemControlForegroundBaseLowBrush}" Opacity="0.2"/>

                        <!-- NORMALIZATION SECTION -->
                        <StackPanel Spacing="12">
                            <TextBlock Text="Recovery &amp; Normalization" Classes="label"/>
                            <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}" CornerRadius="8" Padding="12">
                                <StackPanel Spacing="8">
                                    <TextBlock Name="NormalizationStats" Text="No recovery data yet." FontSize="11" Opacity="0.7" TextWrapping="Wrap"/>
                                    <TextBox Name="NormalizedTextBox" 
                                             IsReadOnly="True" 
                                             Height="80" 
                                             FontSize="12" 
                                             TextWrapping="Wrap" 
                                             Watermark="Clean text will appear here..."
                                             Background="Transparent"
                                             BorderThickness="0"/>
                                    <Button Content="Copy Clean Text" 
                                            Name="CopyNormalizedButton"
                                            Click="OnCopyNormalizedClicked" 
                                            HorizontalAlignment="Right" 
                                            FontSize="11" 
                                            Padding="10,4"
                                            IsEnabled="False"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <Separator Height="1" Background="{DynamicResource SystemControlForegroundBaseLowBrush}" Opacity="0.2"/>

                        <!-- FINDINGS LIST -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="Detailed Findings" Classes="label"/>
                            <StackPanel Name="FindingsPanel" Spacing="4"/>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>