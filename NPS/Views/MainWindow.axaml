<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="NPS.MainWindow"
        Title="Unicode Adversarial Text Research Tool"
        Width="900" Height="650"    
        MinWidth="600" MinHeight="500" 
        WindowStartupLocation="CenterScreen">

    <Window.Styles>
        <Style Selector="TextBlock.h1">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
        </Style>
        <Style Selector="TextBlock.h2">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
        </Style>
        <Style Selector="TextBlock.caption">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
            <Setter Property="LetterSpacing" Value="1"/>
            <Setter Property="Opacity" Value="0.8"/>
        </Style>
        
        <Style Selector="Border.card">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="32"/>
            <Setter Property="Margin" Value="16"/>
            <Setter Property="BoxShadow" Value="0 4 12 0 #15000000"/>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1"/>
                    <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>
        
        <Style Selector="Border.card:pointerover">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumBrush}"/>
            <Setter Property="RenderTransform" Value="scale(1.02)"/>
            <Setter Property="BoxShadow" Value="0 8 16 0 #20000000"/>
        </Style>

        <Style Selector="Button.action">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Margin" Value="0,15,0,0"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*,Auto" Margin="40">

        <!-- HEADER -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Spacing="8" Margin="0,0,0,40">
            <StackPanel Orientation="Horizontal" Spacing="16" HorizontalAlignment="Center">
                <Border Width="6" Height="32" Background="{DynamicResource SystemControlBackgroundAccentBrush}" CornerRadius="3"/>
                <TextBlock Classes="h1" Text="Unicode Adversarial Text"/>
            </StackPanel>
            <TextBlock Classes="caption" Text="RESEARCH TOOL · ACADEMIC PROTOTYPE" HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- MAIN CONTENT cards -->
        <Grid Grid.Row="1" ColumnDefinitions="*,*" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="900">
            
            <!-- ATTACK CARD -->
            <Border Grid.Column="0" Classes="card">
                <Grid RowDefinitions="Auto,Auto,*,Auto">
                    <TextBlock Grid.Row="0" Text="⚡" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    <TextBlock Grid.Row="1" Text="Attack Simulation" Classes="h2" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock Grid.Row="2" Text="Inject invisible characters, homoglyph substitutions and spoofing patterns to test text filters." 
                               TextWrapping="Wrap" TextAlignment="Center" 
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               FontSize="14" LineHeight="20"/>
                    <Button Grid.Row="3" Name="AttackButton" Click="OnAttackClicked" 
                            Content="Launch Simulation" Classes="action accent"/>
                </Grid>
            </Border>

            <!-- DETECT CARD -->
            <Border Grid.Column="1" Classes="card">
                <Grid RowDefinitions="Auto,Auto,*,Auto">
                    <TextBlock Grid.Row="0" Text="🔎" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    <TextBlock Grid.Row="1" Text="Detection &amp; Normalization" Classes="h2" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock Grid.Row="2" Text="Analyze text for Unicode spoofing, visualize hidden characters, and apply normalization defenses." 
                               TextWrapping="Wrap" TextAlignment="Center" 
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               FontSize="14" LineHeight="20"/>
                    <Button Grid.Row="3" Name="DetectButton" Click="OnDetectClicked" 
                            Content="Launch Analysis" Classes="action accent" />
                </Grid>
            </Border>

        </Grid>

        <!-- FOOTER -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="20" HorizontalAlignment="Center" Margin="0,40,0,0">
            <TextBlock Text="Supported Vectors:" VerticalAlignment="Center" Classes="caption"/>
            <ItemsControl>
                <ItemsControl.Items>
                    <x:String>Homoglyphs</x:String>
                    <x:String>Zero-Width</x:String>
                    <x:String>Bidi Override</x:String>
                </ItemsControl.Items>
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="10"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}" CornerRadius="6" Padding="10,5">
                            <TextBlock Text="{Binding}" FontSize="12" FontWeight="Medium"/>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

    </Grid>
</Window>