<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="NPS.Views.AttackWindow"
        Title="Attack Simulation"
        MinWidth="560" MinHeight="300"
        Background="#0F0F13">

    <Window.Styles>
        <Style Selector="Button">
            <Setter Property="Background" Value="#161620"/>
            <Setter Property="Foreground" Value="#5C6CF0"/>
            <Setter Property="BorderBrush" Value="#202030"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1E1E2C"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*,Auto" Margin="36,24,36,20">

        <!-- HEADER -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Margin="0,0,0,20">
            <Button Grid.Column="0" Content="← Back" Click="OnBackClicked"
                    VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Margin="14,0,0,0">
                <StackPanel Orientation="Horizontal" Spacing="9">
                    <Border Width="2.5" Height="16" CornerRadius="2"
                            Background="#5B6BFF" VerticalAlignment="Center"/>
                    <TextBlock Text="Attack Simulation"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="#E2E2EE" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="UNICODE ADVERSARIAL TEXT  ·  RESEARCH TOOL"
                           FontSize="9" Foreground="#28283A"
                           Margin="12,4,0,0" LetterSpacing="2"/>
            </StackPanel>
        </Grid>

        <!-- CONTENT PLACEHOLDER -->
        <Border Grid.Row="1" Background="#111118" BorderThickness="1"
                BorderBrush="#1A1A24" CornerRadius="6"
                VerticalAlignment="Center" HorizontalAlignment="Center"
                Padding="32,20">
            <TextBlock Text="Attack module content goes here."
                       Foreground="#2C2C40" FontSize="11"
                       TextAlignment="Center"/>
        </Border>

        <!-- FOOTER -->
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,10,0,0" Spacing="5">
            <TextBlock Text="Docs &amp; usage →"
                       FontSize="10" Foreground="#22223A"/>
            <TextBlock Text="github.com/stepan-redka/nps-system"
                       FontSize="10" Foreground="#3D4D8A"
                       TextDecorations="Underline" Cursor="Hand"
                       ToolTip.Tip="https://github.com/stepan-redka/nps-system"/>
        </StackPanel>

    </Grid>
</Window>