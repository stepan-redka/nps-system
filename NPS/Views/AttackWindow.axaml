<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="NPS.Views.AttackWindow"
        Title="Attack Simulation"
        MinWidth="800" MinHeight="500" Width="900" Height="600"
        WindowStartupLocation="CenterScreen">

    <Window.Styles>
        <Style Selector="TextBlock.h2">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
        </Style>
        
        <Style Selector="Button.secondary">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="10,6"/>
        </Style>
        
        <Style Selector="TextBox">
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Consolas, monospace"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*,Auto" Margin="30">

        <!-- HEADER -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,20">
            <Button Grid.Column="0" Content="←" Click="OnBackClicked" Classes="secondary" 
                    ToolTip.Tip="Back to Menu" Width="40"/>
            
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                <TextBlock Text="⚡" FontSize="20" VerticalAlignment="Center"/>
                <TextBlock Text="Attack Simulation" Classes="h2" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- CONTENT -->
        <Grid Grid.Row="1" ColumnDefinitions="*, 60, *" Margin="0,10">
            
            <!-- INPUT -->
            <Grid Grid.Column="0" RowDefinitions="Auto, *, Auto">
                <TextBlock Grid.Row="0" Text="Input Text" FontWeight="Medium" Margin="0,0,0,8"/>
                <TextBox Grid.Row="1" Name="InputTextBox" 
                         AcceptsReturn="True" TextWrapping="Wrap"
                         Watermark="Paste text here or load file..."
                         BorderThickness="1"/>
                <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="10" Margin="0,10,0,0">
                    <Button Content="Load File" Click="OnLoadFileClicked"/>
                    <Button Content="Clear" Click="OnClearClicked"/>
                </StackPanel>
            </Grid>

            <!-- ACTIONS (Center) -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10">
                <Button Content="➤" Click="OnRunClicked" Classes="accent" 
                        Width="40" Height="40" CornerRadius="20"
                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                        FontSize="18" ToolTip.Tip="Run Attack"/>
            </StackPanel>

            <!-- OUTPUT -->
            <Grid Grid.Column="2" RowDefinitions="Auto, *, Auto">
                <TextBlock Grid.Row="0" Text="Adversarial Output" FontWeight="Medium" Margin="0,0,0,8"/>
                <TextBox Grid.Row="1" Name="OutputTextBox" 
                         AcceptsReturn="True" TextWrapping="Wrap"
                         IsReadOnly="True"
                         Watermark="Generated text will appear here..."
                         BorderThickness="1" Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"/>
                <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="10" Margin="0,10,0,0" HorizontalAlignment="Right">
                    <Button Content="Copy to Clipboard" Click="OnCopyClicked" Classes="accent"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>